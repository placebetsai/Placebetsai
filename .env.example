# Twitter / X
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_BEARER_TOKEN=your_x_bearer_token
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret
X_CLIENT_ID=your_oauth2_client_id
X_CLIENT_SECRET=your_oauth2_client_secret
X_OAUTH2_TOKEN=your_oauth2_access_token
X_OAUTH2_REFRESH_TOKEN=your_oauth2_refresh_token

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# YouTube OAuth2 (run: node scripts/youtube-auth.js)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token

# Medium (integration token from medium.com/me/settings)
MEDIUM_INTEGRATION_TOKEN=your_medium_integration_token

# Substack
SUBSTACK_EMAIL=your_substack_email
SUBSTACK_PASSWORD=your_substack_password
SUBSTACK_PUB_URL=https://your-substack-pub.com
SUBSTACK_SID=your_substack_session_cookie

# Social handles / config
TIKTOK_USERNAME=your_tiktok_username
TWITTER_USERNAME=your_twitter_username
YOUTUBE_CHANNEL=your_youtube_channel_id
GITHUB_REPO=your_github_username/your_repo
GITHUB_BRANCH=main
SITE_URL=https://yourdomain.com
